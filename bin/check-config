#!/bin/bash

# Script de vérification de la configuration du projet Kubo
# Ce script vérifie que toutes les dépendances et configurations sont correctes

set -e

echo "🔍 Vérification de la configuration du projet Kubo..."
echo ""

# Vérification de PHP
echo "✓ Vérification de PHP..."
if command -v php &> /dev/null; then
    PHP_VERSION=$(php -v | head -n 1 | cut -d " " -f 2 | cut -f1 -d"-")
    echo "  PHP version: $PHP_VERSION"
else
    echo "  ❌ PHP n'est pas installé"
    exit 1
fi

# Vérification de Composer
echo "✓ Vérification de Composer..."
if command -v composer &> /dev/null; then
    COMPOSER_VERSION=$(composer --version | cut -d " " -f 3)
    echo "  Composer version: $COMPOSER_VERSION"
else
    echo "  ❌ Composer n'est pas installé"
    exit 1
fi

# Vérification de Docker
echo "✓ Vérification de Docker..."
if command -v docker &> /dev/null; then
    DOCKER_VERSION=$(docker --version | cut -d " " -f 3 | tr -d ",")
    echo "  Docker version: $DOCKER_VERSION"
else
    echo "  ❌ Docker n'est pas installé"
    exit 1
fi

# Vérification de Docker Compose
echo "✓ Vérification de Docker Compose..."
if docker compose version &> /dev/null; then
    COMPOSE_VERSION=$(docker compose version | cut -d " " -f 4)
    echo "  Docker Compose version: $COMPOSE_VERSION"
else
    echo "  ❌ Docker Compose n'est pas installé"
    exit 1
fi

# Vérification des fichiers .env
echo "✓ Vérification des fichiers de configuration..."
if [ -f ".env" ]; then
    echo "  .env: ✓"
else
    echo "  .env: ❌"
    exit 1
fi

if [ -f ".env.local" ]; then
    echo "  .env.local: ✓"
else
    echo "  .env.local: ⚠️  (optionnel, mais recommandé)"
fi

# Vérification des conteneurs Docker
echo "✓ Vérification des conteneurs Docker..."
if docker compose ps | grep -q "kubodb"; then
    echo "  Base de données: ✓ (en cours d'exécution)"
else
    echo "  Base de données: ⚠️  (non démarré - utilisez 'make start')"
fi

# Vérification de la connexion à la base de données
echo "✓ Vérification de la connexion à la base de données..."
if docker compose ps | grep -q "kubodb.*running"; then
    if docker compose exec -T kubodb pg_isready -U db_user -d kubo &> /dev/null; then
        echo "  Connexion à PostgreSQL: ✓"
    else
        echo "  Connexion à PostgreSQL: ⚠️  (la base de données n'est pas prête)"
    fi
else
    echo "  Connexion à PostgreSQL: ⚠️  (conteneur non démarré)"
fi

# Vérification du dossier vendor
echo "✓ Vérification des dépendances..."
if [ -d "vendor" ]; then
    echo "  Dépendances Composer: ✓"
else
    echo "  Dépendances Composer: ⚠️  (utilisez 'make install')"
fi

echo ""
echo "✅ Vérification terminée !"
echo ""
echo "📝 Commandes utiles:"
echo "  make start   - Démarrer les conteneurs Docker"
echo "  make install - Installer les dépendances"
echo "  make serve   - Démarrer le serveur Symfony"
echo "  make help    - Voir toutes les commandes disponibles"

